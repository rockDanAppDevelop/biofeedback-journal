{
  "expo": {
    "name": "biofeedback-journal",
    "slug": "biofeedback-journal",
    "scheme": "biofeedbackjournal",
    "version": "0.12.0",
    "orientation": "portrait",
    "icon": "./assets/appIcon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/appSplash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001B44"
    },
    "ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.rockdan.biofeedbackjournal",
  "buildNumber": "18",
  "googleServicesFile": "./GoogleService-Info.plist",
  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false
  }
},
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appIcon.png",
        "backgroundColor": "#001B44"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.biofeedbackjournal",
      "versionCode": 18
    },
    "web": {
      "favicon": "./assets/appFavicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34e79a33-b289-4043-a75e-73103f602a41"
      }
    }
  }
}
